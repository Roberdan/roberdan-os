# Microsoft-confidential dossier — never in git (NDA-split, installed into ~/.roberdan-os/private/)
private/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Loop cursor state (durable, not versioned)
.agent-state/

# Per-platform wrappers — fully generated by `bin/sync.sh --emit-only` from the canon.
# Run it locally whenever you need them on disk; test/validate.sh checks generation is
# deterministic instead of diffing against a committed copy. See bin/sync.sh, README.md.
platforms/

# eval/ harness output — generated by eval/run-eval.sh, eval/judge.sh, eval/report.sh.
# Regenerate on demand; see eval/README.md. Commit a specific eval/results/report.md by hand
# (force-add) if you want to keep a dated snapshot.
eval/results/
.gstack/

# Build artifact — regenerate with the make-pdf skill against docs/roberdan-os-paper-en.md.
docs/*.pdf
.gbrain-source
